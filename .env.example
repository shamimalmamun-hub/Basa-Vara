# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# RESEND_API_KEY: Required for sending emails.
RESEND_API_KEY="MY_RESEND_API_KEY"

# ADMIN_NOTIFICATION_EMAIL: Destination email for system notifications (like registrations and payments).
# In Resend's free tier sandbox, this must be your registered Resend account email (e.g., hellothereshamim@gmail.com).
ADMIN_NOTIFICATION_EMAIL="hellothereshamim@gmail.com"

# VITE_API_URL: Required only if frontend is deployed statically (Firebase Hosting / Cloudflare Pages) 
# and server.ts runs elsewhere. Points to your deployed Express server URL (e.g., https://your-server-domain.com).
# Leave blank during local development or unified builds.
VITE_API_URL=""
